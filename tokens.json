{
  "$name": "Lacto Design System",
  "$version": "0.1.0",
  "$description": "Single source for the visual tokens. Run `npm run tokens` to generate src/tokens/tokens.css.",

  "color": {
    "_comment": "Every color has light/dark. The theme switches via [data-theme] on <html>.",
    "bg":           { "light": "#f7f5ef", "dark": "#111110", "use": "Fundo da página / canvas" },
    "panel":        { "light": "#f1eee7", "dark": "#1a1918", "use": "Solid panel surface (sidebar, dock)", "use-pt-BR": "Superfície de painel sólido (sidebar, dock)" },
    "surface":      { "light": "#ffffff", "dark": "#242220", "use": "Raised surface inside a panel (buttons, fields)", "use-pt-BR": "Superfície elevada dentro do painel (botões, campos)" },
    "line":         { "light": "#d7d2c7", "dark": "#2d2b28", "use": "Borders, dividers, slider tracks", "use-pt-BR": "Bordas, divisores, trilhos de slider" },
    "line-strong":  { "light": "#b1b1b1", "dark": "#3d3b38", "use": "Outline border (pill button)", "use-pt-BR": "Borda de contorno (botão pill)" },
    "text":         { "light": "#414141", "dark": "#c8c4bc", "use": "Primary text and solid fills", "use-pt-BR": "Texto principal e preenchimentos sólidos" },
    "muted":        { "light": "#978f7e", "dark": "#857f74", "use": "Secondary text, labels, captions", "use-pt-BR": "Texto secundário, rótulos, legendas" },
    "ink":          { "light": "#111110", "dark": "#f1eee7", "use": "Maximum contrast against bg", "use-pt-BR": "Contraste máximo sobre bg" },
    "hover":        { "light": "#ebe6db", "dark": "#2f2c28", "use": "Neutral hover fill", "use-pt-BR": "Fundo de hover neutro" },
    "accent":       { "light": "#ffc800", "dark": "#ffc800", "use": "Lacto yellow: active state, highlight hover, focus", "use-pt-BR": "Amarelo Lacto: estado ativo, hover de destaque, foco" },
    "accent-ink":   { "light": "#3a3526", "dark": "#2a2618", "use": "Text on accent", "use-pt-BR": "Texto sobre accent" },
    "dot":          { "light": "#d9d9d9", "dark": "#333330", "use": "Dot of the dotted background", "use-pt-BR": "Ponto do fundo pontilhado" },
    "danger":       { "light": "#e03131", "dark": "#e03131", "use": "Destructive, delete badge", "use-pt-BR": "Destrutivo, badge de excluir" },
    "danger-strong":{ "light": "#c92a2a", "dark": "#c92a2a", "use": "Destructive hover", "use-pt-BR": "Hover do destrutivo" },
    "success":      { "light": "#37b24d", "dark": "#37b24d", "use": "Confirmation, released area", "use-pt-BR": "Confirmação, área liberada" },
    "info":         { "light": "#3b82f6", "dark": "#3b82f6", "use": "Momentary modifier (Shift/Alt/Cmd held)", "use-pt-BR": "Modificador momentâneo (Shift/Alt/Cmd ativo)" },
    "glass":        { "light": "rgba(243,240,233,0.66)", "dark": "rgba(26,25,23,0.62)", "use": "Floating panel with blur", "use-pt-BR": "Painel flutuante com blur" },
    "glass-solid":  { "light": "rgba(245,242,236,0.94)", "dark": "rgba(22,21,19,0.95)", "use": "Opaque fallback when blur is turned off", "use-pt-BR": "Fallback opaco quando o blur é desligado" },
    "glass-border": { "light": "rgba(255,255,255,0.5)",  "dark": "rgba(255,255,255,0.07)", "use": "Glass border", "use-pt-BR": "Borda do vidro" },
    "shadow":       { "light": "rgba(60,50,30,0.14)",    "dark": "rgba(0,0,0,0.45)", "use": "Base color for shadows", "use-pt-BR": "Cor base das sombras" }
  },

  "font": {
    "sans": "\"Outfit\", system-ui, -apple-system, \"Segoe UI\", sans-serif",
    "mono": "\"Ubuntu Mono\", ui-monospace, SFMono-Regular, Menlo, monospace",
    "_rule": "Every number, value, hex, coordinate and text field uses mono. Running text and labels use sans."
  },

  "font-size": {
    "9":  "9px",  "10": "10px", "11": "11px", "12": "12px",
    "13": "13px", "14": "14px", "15": "15px", "20": "20px", "26": "26px",
    "_rule": "13px is the default control size. 12px for labels/captions. 11px for the uppercase overline."
  },

  "font-weight": { "regular": "400", "medium": "500", "semibold": "600", "bold": "700" },

  "letter-spacing": { "overline": "0.6px", "tight": "0.01em" },

  "radius": {
    "xs": "4px", "sm": "6px", "md": "8px", "lg": "10px",
    "xl": "12px", "2xl": "14px", "3xl": "15px", "4xl": "20px",
    "pill": "30px", "full": "999px"
  },

  "space": {
    "0": "0", "1": "2px", "2": "4px", "3": "6px", "4": "8px", "5": "10px",
    "6": "12px", "7": "14px", "8": "16px", "9": "18px", "10": "20px", "12": "24px"
  },

  "size": {
    "control-xs": "26px", "control-sm": "30px", "control": "34px",
    "control-md": "36px", "control-lg": "38px",
    "switch-w": "70px", "switch-h": "17px", "switch-thumb": "39px",
    "switch-compact-w": "44px", "switch-compact-h": "18px",
    "swatch": "34px", "swatch-lg": "46px", "tile": "46px",
    "sidebar": "320px"
  },

  "icon-size": {
    "xs": "14px", "sm": "16px", "md": "20px", "lg": "24px", "xl": "32px",
    "_rule": "Google Material Symbols Outlined. md (20px) is the default inside 34-36px buttons."
  },

  "icon-weight": { "regular": "400", "medium": "500", "bold": "600" },

  "motion": {
    "instant": "0.11s", "fast": "0.12s", "base": "0.15s", "hover": "0.16s",
    "slider": "0.18s", "slow": "0.22s", "panel": "0.28s",
    "ease": "cubic-bezier(0.4, 0, 0.2, 1)",
    "ease-out": "ease-out",
    "_rule": "Hover/color = hover(0.16s). Press = fast(0.12s). Layout/morph = slow(0.22s). Open/close section = panel(0.28s). Slider = slider(0.18s)."
  },

  "press": { "scale-strong": "0.93", "scale-soft": "0.96" },

  "elevation": {
    "panel": "0 8px 28px var(--lc-shadow)",
    "popover": "0 6px 20px var(--lc-shadow)",
    "badge": "0 1px 3px rgba(0,0,0,0.35)",
    "toast": "0 8px 28px var(--lc-shadow)"
  },

  "blur": { "glass": "blur(16px) saturate(1.4)" },

  "focus": {
    "ring": "0 0 0 2px var(--lc-accent)",
    "ring-inset": "inset 0 0 0 2px var(--lc-accent)",
    "_rule": "Focus is always the accent ring. Never remove an outline without restoring the ring."
  },

  "z": { "sidebar": "50", "float": "10", "popover": "1000", "toast": "1100" }
}
